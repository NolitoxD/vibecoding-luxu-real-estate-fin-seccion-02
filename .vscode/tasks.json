{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "next: dev (debug)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "env": {
          "NODE_OPTIONS": "--inspect"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "next",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "starting|compiling",
          "endsPattern": "ready|compiled|error"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
