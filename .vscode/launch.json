{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug server-side (Turbopack, puerto 9230)",
      "type": "node",
      "request": "attach",
      "port": 9230,
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${workspaceFolder}/*",
        "turbopack://[project]/*": "${workspaceFolder}/*"
      }
    },
    {
      "name": "Next.js: debug server-side (elegir proceso)",
      "type": "node",
      "request": "attach",
      "processId": "${command:PickProcess}",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${workspaceFolder}/*",
        "turbopack://[project]/*": "${workspaceFolder}/*"
      }
    },
    {
      "name": "Next.js: debug client-side (Edge) ⭐",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${workspaceFolder}/*",
        "turbopack://[project]/*": "${workspaceFolder}/*"
      }
    },
    {
      "name": "Next.js: debug client-side (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${workspaceFolder}/*",
        "turbopack://[project]/*": "${workspaceFolder}/*"
      }
    },
    {
      "name": "Next.js: debug client-side (Firefox)",
      "type": "firefox",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "pathMappings": [
        {
          "url": "webpack://_N_E",
          "path": "${workspaceFolder}"
        },
        {
          "url": "webpack://[project]",
          "path": "${workspaceFolder}"
        },
        {
          "url": "turbopack://[project]",
          "path": "${workspaceFolder}"
        },
        {
          "url": "webpack://",
          "path": "${workspaceFolder}"
        }
      ]
    },
    {
      "name": "Next.js: debug full-stack (sin Turbopack)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:debug"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack://_N_E/*": "${workspaceFolder}/*"
      },
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "debugWithEdge"
      }
    }
  ]
}
